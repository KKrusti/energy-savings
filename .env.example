# energy-savings — variables de entorno para desarrollo local
# Copia este fichero a .env y rellena los valores reales.
# NUNCA subas .env al repositorio (ya está en .gitignore).

# ── Servidor ──────────────────────────────────────────────────────────────────
# Puerto TCP en el que escucha el devserver (por defecto: 8080)
ADDR=:8080

# ── Base de datos (Neon PostgreSQL) ───────────────────────────────────────────
# Connection string de Neon. En Vercel se inyecta automáticamente como DATABASE_URL
# cuando conectas el proyecto a una base de datos Neon.
# Para desarrollo local, cópialo desde: Vercel → tu proyecto → Settings → Environment Variables
# O genera uno nuevo desde: https://console.neon.tech → tu proyecto → Connection Details
# Usa la URL con -pooler para serverless, sin -pooler para desarrollo local.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── CORS (opcional) ───────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Solo necesario en desarrollo local
# donde el frontend (5173) y el backend (8080) corren en puertos distintos.
# En producción Vercel están en el mismo dominio y no es necesario.
CORS_ALLOWED_ORIGINS=http://localhost:5173
